# ==========================================
# PyQt6 / Qt Specific
# ==========================================
# Ignore compiled Python UI files generated by pyuic6
# (Keep your original .ui files, but ignore the auto-generated .py layout files)
*_rc.py
*家ui.py
# If you name your compiled UI files explicitly (e.g., ui_main.py), uncomment below:
# ui_*.py

# Ignore compiled Qt Resource files generated by pyrcc6 (if used)
*_qrc.py

# Qt Creator project local files / workspaces
*.ui.user

# ==========================================
# Python Core & Bytecode
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so

# ==========================================
# Virtual Environments & Package Managers
# ==========================================
.venv/
venv/
ENV/
env/
_venv/
.python-version
.pep582/
__pypackages__/

# ==========================================
# Distribution, Packaging, & Executables
# ==========================================
# Ignore standalone executables if you use PyInstaller or cx_Freeze
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.spec

# ==========================================
# IDEs, Editors, & OS Artifacts
# ==========================================
# PyCharm
.idea/

# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Operating System Files
.DS_Store
Thumbs.db

# ==========================================
# Testing, Logs, & Environment Variables
# ==========================================
*.log
.cache/
.pytest_cache/
.coverage
htmlcov/
.env
.flaskenv
